---
import { Twitter } from "lucide-astro";
---

<footer
  class="mx-auto mt-20 flex max-w-screen-lg items-center justify-between space-x-2 border-t px-4 py-6 sm:px-6 lg:px-8"
>
  <p class="text-sm text-muted-foreground">
    Copyright &copy; {new Date().getFullYear()} Hector Oropesa - All rights reserved
  </p>
  <a
    href="https://twitter.com/HectorOropesa1"
    target="_blank"
    class="hover:link transform text-muted-foreground transition-all duration-200 hover:scale-95 hover:text-foreground active:scale-105"
  >
    <Twitter />
  </a>
</footer>
