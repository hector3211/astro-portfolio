---
import ToggleThemeButton from "../components/ToggleTheme";
import MobileMenu from "../components/MobileMenu";
import { ExternalLink, Github } from "lucide-astro";
---

<nav
  transition:persist
  class="fixed inset-x-0 top-0 z-50 border-b bg-background/85 backdrop-blur-xl"
>
  <div
    class="mx-auto flex h-16 w-full max-w-screen-lg items-center justify-between px-4 sm:px-6 lg:px-8"
  >
    <div class="flex items-center">
      <a
        href="/"
        class="text-lg font-bold tracking-tight text-foreground transition duration-200 hover:text-foreground/75"
      >
        Hector Oropesa
      </a>
    </div>
    <div class="flex items-center gap-3 sm:gap-5">
      <div
        class="hidden items-center gap-6 text-sm font-medium text-muted-foreground md:flex"
      >
        <a
          href="/#projects"
          class="transition duration-200 hover:text-foreground"
        >
          Projects
        </a>
        <a
          href="/#contact"
          class="transition duration-200 hover:text-foreground"
        >
          Contact
        </a>
        <a
          href="https://github.com/hector3211"
          target="_blank"
          rel="noreferrer"
          class="flex items-center gap-1.5 transition duration-200 hover:text-foreground"
        >
          <Github class="h-4 w-4" /> GitHub
        </a>
        <a
          href="https://github.com/hector3211/astro-portfolio"
          target="_blank"
          rel="noreferrer"
          class="flex items-center gap-1.5 transition duration-200 hover:text-foreground"
        >
          Source <ExternalLink class="h-3.5 w-3.5" />
        </a>
      </div>
      <ToggleThemeButton client:load />
      <MobileMenu client:load />
    </div>
  </div>
</nav>
