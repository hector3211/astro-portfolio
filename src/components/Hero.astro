---
import { Button } from "../components/ui/button.tsx";
---

<section class="body-font mx-auto w-full max-w-5xl px-4 pb-8 pt-12 sm:pt-14">
  <div class="mx-auto flex max-w-3xl flex-col items-center text-center">
    <h1 class="text-5xl font-bold tracking-tight sm:text-6xl md:text-7xl">
      Hector Oropesa
    </h1>
    <a href="#contact" class="mt-7 flex w-full max-w-60 justify-center">
      <Button
        className="w-full bg-teal-500 shadow-sm shadow-teal-600 transition hover:bg-teal-500/80"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          width="20"
          height="20"
        >
          <rect x="3" y="4" width="18" height="16" rx="2" ry="2"></rect>
          <polyline points="3 6 12 13 21 6"></polyline>
        </svg>
        <p class="sm:text-md px-1">Contact</p>
      </Button>
    </a>
  </div>
  <div class="mx-auto mt-14 max-w-4xl">
    <p class="text-left text-base leading-8 text-foreground/90 sm:text-lg">
      Hi, I'm Hector. I build full-stack applications and cloud infrastructure
      with a focus on practical systems that make real workflows easier. My work
      usually involves TypeScript, React, TanStack, PostgreSQL, AWS, and
      Terraform. I enjoy turning messy business problems into simple tools,
      improving deployment workflows, and learning how each part of a system fits
      together.
    </p>
  </div>
</section>
