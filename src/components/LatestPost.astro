---
import { getCollection } from "astro:content";
import { ArrowRight } from "lucide-astro";

const latestPost = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)[0];

const formattedDate = latestPost?.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

{
  latestPost && (
    <section class="mx-auto w-full max-w-screen-lg px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
      <div class="mb-4 flex items-center justify-between gap-4">
        <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-muted-foreground">
          Latest post
        </h2>
        <a
          href="/blog"
          class="text-sm font-medium text-muted-foreground underline-offset-4 hover:text-foreground hover:underline"
        >
          All posts
        </a>
      </div>

      <a
        href={`/blog/${latestPost.id}`}
        class="group block rounded-3xl border bg-muted/20 px-5 py-5 outline-none transition duration-200 hover:border-foreground/20 hover:bg-muted/30 focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-4 focus-visible:ring-offset-background sm:px-6 sm:py-6"
        aria-label={`Read latest blog post: ${latestPost.data.title}`}
      >
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div class="max-w-3xl">
            <time
              datetime={latestPost.data.date.toISOString()}
              class="text-sm text-muted-foreground"
            >
              {formattedDate}
            </time>
            <h3 class="mt-2 text-xl font-semibold tracking-tight sm:text-2xl">
              {latestPost.data.title}
            </h3>
            <p class="mt-3 text-sm leading-6 text-muted-foreground sm:text-base">
              {latestPost.data.description}
            </p>
          </div>

          <span class="inline-flex shrink-0 items-center gap-2 text-sm font-medium text-teal-700 dark:text-teal-300">
            Read
            <ArrowRight class="h-4 w-4 transition duration-200 group-hover:translate-x-1" />
          </span>
        </div>
      </a>
    </section>
  )
}
