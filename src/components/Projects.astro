---
import { ExternalLink } from "lucide-astro";

const projects = [
  {
    title: "Confidential AWS Infrastructure",
    type: "Client cloud infrastructure work",
    summary:
      "Terraform-managed AWS environment focused on repeatable infrastructure, remote state, runtime migration, and CI/CD planning.",
    stack: ["AWS", "Terraform"],
    details: [
      "Managed Terraform remote state with S3 versioning and native S3 lockfiles.",
      "Planned CI/CD workflows using GitHub Actions and AWS OIDC instead of long-lived keys.",
      "Worked through runtime direction from App Runner toward ECS.",
      "Improved module boundaries around networking, runtime, registry, IAM, and deployment responsibilities.",
    ],
  },
  {
    title: "CM Data",
    type: "Commercial trucking repair application",
    summary:
      "A repair operations app built to make estimator workflows faster and easier.",
    stack: [
      "TanStack Start",
      "PostgreSQL",
      "Drizzle",
      "Coolify",
      "Self-hosted on-prem",
    ],
    details: [
      "Built for commercial trucking repair operations.",
      "Helps estimators move through repair and estimate workflows with less friction.",
      "Uses PostgreSQL and Drizzle for the data layer.",
      "Self-hosted on-prem with Coolify for deployment and operations.",
    ],
  },
  {
    title: "GraniteSync",
    type: "Production workflow SaaS",
    summary:
      "A workflow tool for granite shops with role-based access, job management, inventory, uploads, and fabricator notifications.",
    stack: ["AWS", "S3", "PostgreSQL", "Better Auth", "TanStack Start"],
    details: [
      "Built admin workflows for inventory management and job creation.",
      "Added project image uploads and individual fabricator profiles.",
      "Sent email notifications when fabricators were assigned new jobs.",
      "Focused on simplifying production coordination for granite companies.",
    ],
  },
  {
    title: "GD Granite",
    type: "Local business website",
    summary:
      "A fast, responsive website for a granite shop with a validated contact flow and polished service presentation.",
    stack: ["Astro", "TypeScript", "React", "Responsive design"],
    details: [
      "Created a production website for a local granite business.",
      "Built a validated form flow for cleaner customer inquiries.",
      "Focused on speed, responsiveness, and clear service presentation.",
    ],
    live: "https://gdgranite.com",
  },
  {
    title: "RustFlix",
    type: "Movie application",
    summary:
      "A streaming-style web app built around modern full-stack patterns and fast frontend rendering.",
    stack: ["Next.js", "Server Components", "Drizzle", "TypeScript"],
    details: [
      "Built a video streaming interface with a full-stack application structure.",
      "Used server components for fast frontend rendering.",
      "Worked with Drizzle for typed data access and backend performance.",
    ],
    live: "https://rustflix.hectorcodes.dev",
    github: "https://github.com/hector3211/rust-fullstack",
  },
  {
    title: "Travel",
    type: "Travel application",
    summary:
      "A travel-focused web app with weather-aware trip context and responsive UI patterns.",
    stack: ["Next.js", "Weather API", "Responsive design", "Animations"],
    details: [
      "Built real-time weather context into a travel experience.",
      "Designed responsive layouts for travelers planning across devices.",
      "Used animation and modern UI patterns to make the app feel more engaging.",
    ],
    live: "https://travel.hectorcodes.dev",
    github: "https://github.com/hector3211/Travel-website",
  },
  {
    title: "Supreme Granite",
    type: "Granite shop website",
    summary:
      "A product-focused business site with inventory browsing, gallery filtering, and customer inquiry flows.",
    stack: ["Astro", "TypeScript", "React", "Tailwind CSS"],
    details: [
      "Built a responsive website for browsing granite products and services.",
      "Added inventory and gallery experiences for easier product discovery.",
      "Included inquiry and newsletter flows for customer engagement.",
    ],
    live: "https://granite.hectorcodes.dev",
    github: "https://github.com/hector3211/supreme-granite",
  },
  {
    title: "Headers",
    type: "Ecommerce application",
    summary:
      "A storefront-style application focused on product presentation and clean shopping flows.",
    stack: ["Astro", "TypeScript", "React", "Ecommerce UI"],
    details: [
      "Built a product-focused frontend with clear browsing and detail views.",
      "Focused on fast page loads and responsive ecommerce presentation.",
      "Used a modern Astro and React stack for interactive UI pieces.",
    ],
    live: "https://headers.hectorcodes.dev",
    github: "https://github.com/hector3211/headers",
  },
];
---

<section class="mx-auto w-full max-w-5xl px-4 py-16 sm:py-24">
  <div class="mb-8 sm:mb-10">
    <h2 class="text-3xl font-bold tracking-tight sm:text-5xl">Projects</h2>
  </div>

  <div class="space-y-3">
    {
      projects.map((project) => (
        <details class="group rounded-2xl border bg-background/70 shadow-sm transition duration-200 open:border-foreground/20 hover:border-foreground/20 hover:bg-muted/30">
          <summary class="grid cursor-pointer list-none gap-4 p-5 marker:hidden sm:grid-cols-[1fr_auto] sm:items-start sm:p-6 [&::-webkit-details-marker]:hidden">
            <div class="min-w-0">
              <div class="mb-2 flex flex-wrap items-center gap-2">
                <h3 class="text-xl font-semibold tracking-tight">{project.title}</h3>
                <span class="rounded-full border px-2.5 py-1 text-xs font-medium text-muted-foreground">
                  {project.type}
                </span>
              </div>
              <p class="max-w-3xl text-sm leading-6 text-muted-foreground sm:text-base">
                {project.summary}
              </p>
              <div class="mt-3 flex flex-wrap gap-2">
                {project.stack.slice(0, 4).map((item) => (
                  <span class="rounded-full bg-muted px-2.5 py-1 text-xs text-muted-foreground">
                    {item}
                  </span>
                ))}
              </div>
            </div>
            <span class="text-sm font-medium text-muted-foreground transition group-open:rotate-45 sm:mt-1">
              +
            </span>
          </summary>

          <div class="border-t px-5 pb-5 pt-4 sm:px-6 sm:pb-6">
            <div class="grid gap-5 md:grid-cols-[1.5fr_1fr]">
              <ul class="space-y-2 text-sm leading-6 text-muted-foreground">
                {project.details.map((detail) => (
                  <li class="flex gap-2">
                    <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-foreground/60" />
                    <span>{detail}</span>
                  </li>
                ))}
              </ul>

              <div class="space-y-4">
                <div>
                  <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">
                    Tech Stack
                  </p>
                  <div class="flex flex-wrap gap-2">
                    {project.stack.map((item) => (
                      <span class="rounded-full border px-2.5 py-1 text-xs text-muted-foreground">
                        {item}
                      </span>
                    ))}
                  </div>
                </div>

                {(project.live || project.github) && (
                  <div class="flex flex-wrap gap-3 text-sm font-medium">
                    {project.live && (
                      <a
                        href={project.live}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex items-center gap-1 underline-offset-4 hover:underline"
                      >
                        Live site <ExternalLink class="h-3.5 w-3.5" />
                      </a>
                    )}
                    {project.github && (
                      <a
                        href={project.github}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex items-center gap-1 underline-offset-4 hover:underline"
                      >
                        Source <ExternalLink class="h-3.5 w-3.5" />
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
          </div>
        </details>
      ))
    }
  </div>
</section>
